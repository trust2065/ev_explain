---
import type { CollectionEntry } from 'astro:content';
import LuxuryLayout from './LuxuryLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;
---

<LuxuryLayout title={`${title} | EV3 EXPLAIN`} description={description}>
	<article class="article-content">
		{heroImage && <div class="home-bg" style={`background-image: url(${typeof heroImage === 'string' ? heroImage : heroImage.src})`}></div>}
		<div class="prose">
			<header class="article-header">
				<div class="meta">
					<span class="category">{category}</span>
					<span class="divider">/</span>
					<FormattedDate date={pubDate} />
					{updatedDate && (
						<span class="last-updated">
							(更新於 <FormattedDate date={updatedDate} />)
						</span>
					)}
				</div>
				<h1 class="title">{title}</h1>
				<hr class="luxury-hr" />
			</header>
			<slot />
		</div>
	</article>
</LuxuryLayout>

<style is:global>
	.home-bg {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-size: cover;
		background-position: center;
		opacity: 0.05;
		z-index: -1;
		pointer-events: none;
	}
	.article-content {
		max-width: 860px;
		margin: 0 auto;
		padding: 40px 24px 120px;
	}
	@media (max-width: 1024px) {
		.article-content {
			padding: 24px 0 80px;
		}
		.title {
			font-size: 2.5rem;
			margin-bottom: 24px;
		}
		.prose {
			font-size: 18px;
		}
		.prose h2 {
			font-size: 1.75rem;
			margin-top: 2em;
		}
	}
	.article-header {
		margin-bottom: 48px;
	}
	.meta {
		font-family: var(--font-sans);
		font-size: 13px;
		color: var(--text-tertiary);
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 24px;
		text-transform: uppercase;
		letter-spacing: 2px;
		font-weight: 500;
	}
	.category {
		color: var(--accent-gold);
		font-weight: 500;
	}
	.title {
		font-size: 4rem;
		line-height: 1.1;
		margin-bottom: 32px;
		font-family: var(--font-serif);
		color: var(--text-primary);
		letter-spacing: -0.01em;
	}
	.luxury-hr {
		border: none;
		border-top: 1px solid var(--border-color);
		margin: 32px 0;
	}
	/* Prose styling */
	.prose {
		color: var(--text-secondary);
		line-height: 1.85;
		font-family: var(--font-sans);
		font-size: 20px; /* Slightly larger for main text */
	}
	.prose h2 {
		font-size: 2.25rem;
		margin-top: 2.5em;
		margin-bottom: 1.25em;
		color: var(--text-primary);
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 16px;
	}
	.prose h3 {
		font-size: 1.75rem;
		margin-top: 2em;
		margin-bottom: 1em;
		color: var(--text-primary);
	}
	.prose p {
		margin-bottom: 2rem;
		letter-spacing: 0.01em;
	}
	.prose ul, .prose ol {
		margin-bottom: 2rem;
		padding-left: 1.5em;
	}
	.prose li {
		margin-bottom: 0.8rem;
	}
	.prose strong {
		color: var(--text-primary);
		font-weight: 600;
	}
</style>
