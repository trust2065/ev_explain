---
import { getCollection } from 'astro:content';
import LuxuryLayout from '../../layouts/LuxuryLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import homeBg from '../../assets/ev3_indepth.png';

const posts = (await getCollection('blog')).sort((a, b) => {
	const orderA = a.data.sortOrder ?? 999;
	const orderB = b.data.sortOrder ?? 999;
	if (orderA !== orderB) return orderA - orderB;
	return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});
---

<LuxuryLayout title="所有文章 | EV EXPLAIN" description="探索完整的電動車知識庫">
	<div class="home-bg" style={`background-image: url(${homeBg.src})`}></div>
	<header class="blog-header">
		<h1 class="page-title">文章庫</h1>
	</header>

	<section class="grid-section">
		<div class="article-grid">
			{
				posts.map((post) => (
					<ArticleCard 
						category={post.data.category || '知識庫'}
						title={post.data.title}
						href={`/blog/${post.id}/`}
						heroImage={post.data.heroImage}
					/>
				))
			}
		</div>
	</section>
</LuxuryLayout>

<style>
	.home-bg {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-size: cover;
		background-position: center;
		opacity: 0.05;
		z-index: -1;
		pointer-events: none;
	}
	.blog-header {
		margin-bottom: 48px;
	}
	.page-title {
		font-size: 48px;
	}
	.article-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 20px;
	}
</style>
