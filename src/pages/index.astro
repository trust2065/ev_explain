---
import LuxuryLayout from '../layouts/LuxuryLayout.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Search from '../components/Search.astro';
import { getCollection } from 'astro:content';
import homeBg from '../assets/ev3_indepth.png';

const allPosts = await getCollection('blog');
const selectedIds = ['charging-guide', 'hey-kia', 'how-to-use-i-pedal', 'kia-connect-connectivity'];
const posts = selectedIds.map(id => allPosts.find(p => p.id === id)).filter(Boolean);

const featuredPost = posts[0];
const otherPosts = posts.slice(1);
---

<LuxuryLayout>
	<header class="home-header">
		<h1 class="page-title">電動車知識庫</h1>
		<div class="search-container">
			<Search />
		</div>
	</header>

	<section class="featured-section">
		{featuredPost && (
			<FeaturedPost 
				category={featuredPost.data.category || '精選文章'}
				title={featuredPost.data.title}
				description={featuredPost.data.description}
				href={`/blog/${featuredPost.id}/`}
				heroImage={featuredPost.data.heroImage}
			/>
		)}
	</section>

	<section class="grid-section">
		<div class="article-grid">
			{otherPosts.map(post => (
				<ArticleCard 
					category={post.data.category || '知識庫'}
					title={post.data.title}
					href={`/blog/${post.id}/`}
					heroImage={post.data.heroImage}
				/>
			))}
		</div>
	</section>
</LuxuryLayout>

<style>
	.home-bg {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-size: cover;
		background-position: center;
		opacity: 0.05;
		z-index: -1;
		pointer-events: none;
	}
	.home-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 48px;
	}
	.page-title {
		font-size: 48px;
	}
	.search-bar {
		width: 400px;
		height: 48px;
		background: var(--bg-surface);
		border: 1px solid var(--accent-gold-alpha);
		display: flex;
		align-items: center;
		padding: 0 16px;
		gap: 12px;
		cursor: text;
	}
	.search-placeholder {
		font-family: var(--font-sans);
		font-size: 14px;
		color: var(--text-tertiary);
	}
	.featured-section {
		margin-bottom: 48px;
	}
	.article-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}
</style>
