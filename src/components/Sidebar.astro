---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = [...posts].sort((a, b) => {
	const orderA = Number(a.data.sortOrder ?? 999);
	const orderB = Number(b.data.sortOrder ?? 999);
	
	if (orderA !== orderB) return orderA - orderB;
	
	// If sortOrder is same, sort by date descending
	return b.data.pubDate.getTime() - a.data.pubDate.getTime();
});

const { pathname } = Astro.url;

const isHomePage = pathname === '/' || pathname === '/index.html';
const isBlogPage = pathname.startsWith('/blog');

const navItems = [
	{ label: '首頁', icon: 'layout-dashboard', href: '/', active: isHomePage },
	{ label: '文章庫', icon: 'book-open', href: '/blog/', active: isBlogPage && pathname.endsWith('/blog/') },
];
---

<aside class="sidebar">
	<div class="logo-area">
		<img src="/favicon.png" alt="EV Explain Logo" class="side-logo" />
		<span class="logo-mark">EV Explain</span>
	</div>

	<nav class="navigation">
		{navItems.map((item) => (
			<a href={item.href} class:list={['nav-item', { active: item.active }]}>
				<span class="icon">{/* Icon Placeholder */}</span>
				{item.label}
			</a>
		))}
		
		<div class="nav-section">
			<span class="section-title">所有文章</span>
			{sortedPosts.map((post) => (
				<a 
					href={`/blog/${post.id}/`} 
					class:list={['nav-sub-item', { active: pathname === `/blog/${post.id}/` || pathname === `/blog/${post.id}` }]}
				>
					{post.data.title}
				</a>
			))}
		</div>
	</nav>
</aside>

<style>
	.sidebar {
		width: 280px;
		height: 100vh;
		position: sticky;
		top: 0;
		background: var(--bg-primary);
		border-right: 1px solid var(--border-color);
		padding: 40px 28px;
		display: flex;
		flex-direction: column;
		gap: 40px;
		overflow-y: auto;
	}
	.logo-area {
		display: flex;
		align-items: center;
		gap: 12px;
	}
	.logo-mark {
		font-family: var(--font-serif);
		font-size: 24px;
		font-weight: 600;
		color: var(--accent-gold);
	}
	.side-logo {
		width: 32px;
		height: 32px;
		object-fit: contain;
	}
	.navigation {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.nav-item {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 14px 0;
		text-decoration: none;
		font-family: var(--font-sans);
		font-size: 16px;
		font-weight: 400;
		color: var(--text-secondary);
		transition: color 0.2s ease;
	}
	.nav-item.active {
		color: var(--text-primary);
		font-weight: 500;
	}
	.nav-item.active .icon {
		color: var(--accent-gold);
	}
	.nav-item:hover {
		color: var(--text-primary);
	}
	.nav-section {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin-top: 24px;
	}
	.section-title {
		font-family: var(--font-sans);
		font-size: 13px;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--text-tertiary);
		padding-bottom: 8px;
	}
	.nav-sub-item {
		display: block;
		text-decoration: none;
		font-family: var(--font-sans);
		font-size: 15px;
		font-weight: 400;
		color: var(--text-secondary);
		padding: 8px 0;
		transition: all 0.2s ease;
		line-height: 1.4;
	}
	.nav-sub-item:hover {
		color: var(--text-primary);
		transform: translateX(4px);
	}
	.nav-sub-item.active {
		color: var(--accent-gold);
		font-weight: 500;
	}

	@media (max-width: 1024px) {
		.sidebar {
			width: 100%;
			height: auto;
			position: relative;
			border-right: none;
			border-bottom: 1px solid var(--border-color);
			padding: 20px 24px;
			gap: 20px;
		}
		.nav-section {
			display: none;
		}
		.navigation {
			flex-direction: row;
			gap: 20px;
		}
		.nav-item {
			padding: 0;
		}
		.logo-area {
			margin-bottom: 0;
		}
	}
</style>
